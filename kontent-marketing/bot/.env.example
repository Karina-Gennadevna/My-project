# ==============================
# КЛЮЧИ — скопируй в .env
# ==============================

# 1. Telegram Bot Token
# Получить: https://t.me/BotFather → /newbot
TELEGRAM_TOKEN=your_telegram_bot_token_here

# 2. OpenRouter API Key
# Получить: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# 3. Разрешённые пользователи (твой Telegram user_id)
# Узнать свой ID: https://t.me/userinfobot
# Несколько ID через запятую: 123456789,987654321
ALLOWED_USER_IDS=your_telegram_user_id_here

# 4. Модели (можно менять на любые доступные в OpenRouter)
MODEL_SONNET=anthropic/claude-sonnet-4-5
MODEL_OPUS=anthropic/claude-opus-4-5
MODEL_HAIKU=anthropic/claude-haiku-4-5-20251001
